# Copy to configs/daily_downloader.env and edit local overrides if needed.
# Leave PYTHON_BIN empty to let scripts/runtime_env.sh auto-detect the active
# fintech env across /root, /home/user, or a local conda/mamba install.

PYTHON_BIN=

# market-daemon checks each market close window and runs each market at most once per local market day.
RUN_MODE=market-daemon
MARKET_CHECK_INTERVAL_SECONDS=300
MAX_CYCLES=0
FAIL_FAST=0
DAILY_PARALLEL_GROUPS=1
TEE_LOG=1

RUN_LOG_DIR=artifacts/daily_downloader
RUN_RECORD_FILE=artifacts/daily_downloader/daily_runs.tsv
LOCK_FILE=artifacts/daily_downloader/daily.lock
SCHEDULE_STATE_FILE=artifacts/daily_downloader/market_schedule.state
DAILY_DOWNLOADER_PID_FILE=artifacts/daily_downloader/daily_downloader.pid
DAILY_DOWNLOADER_LAUNCH_LOG=artifacts/daily_downloader/daily_downloader_daemon.log

WORKERS=16
ASSET_WORKERS=2
RETRIES=2
REPAIR_OVERLAP_DAYS=7
DAILY_STALE_MAX_LAG_DAYS=14
PRECHECK_FILE_TIMEOUT_SECONDS=20
REPAIR_SYMBOL_TIMEOUT_SECONDS=90

RUN_YAHOO=1
YAHOO_ASSETS="tw_stocks us_stocks crypto forex"
YAHOO_DAILY_DISCOVER_SYMBOLS=1
YAHOO_DAILY_RETRY_KNOWN_MISSING_SYMBOLS=0
YAHOO_RETRY_BLACKLISTED_REPAIR_SYMBOLS=0
YAHOO_INCLUDE_TW_DELISTED=1
YAHOO_INCLUDE_US_DELISTED=1
YAHOO_STEP_TIMEOUT_SECONDS=0

RUN_TW_PUBLIC_DATA=1
TW_PUBLIC_DATASETS=all
TW_PUBLIC_OUTPUT_DIR=data_tw_public
TW_PUBLIC_WORKERS=4
TW_PUBLIC_TIMEOUT=30
TW_PUBLIC_RETRIES=3
TW_PUBLIC_RETRY_BACKOFF=1.0
TW_PUBLIC_SLEEP=0.15
TW_PUBLIC_SKIP_RAW=0
TW_PUBLIC_MAX_DATES=
RUN_TW_PUBLIC_FEATURES=1
TW_PUBLIC_FEATURE_PATH=data_tw_public/features/tw_public_stock_daily.parquet
TW_PUBLIC_FEATURE_SYMBOLS_ROOT=data_yahoo/tw_stocks
TW_PUBLIC_MARKET_SYMBOL=__MARKET__

FRANKFURTER_OUTPUT_DIR=data_forex_frankfurter
FRANKFURTER_SYMBOLS_FILE=configs/forex_all_pairs_frankfurter.txt
FRANKFURTER_TIMEOUT=30
FRANKFURTER_SKIP_MANIFEST=0
RUN_FRANKFURTER=1

RUN_PEPPERSTONE_GROUPS=1
PEPPERSTONE_WORKERS=8

RUN_CEX_PERP=1
# OKX/Bybit crypto perpetual updates always use 15-minute bars.
OKX_WORKERS=16
OKX_REQUEST_INTERVAL=0.1
OKX_MAX_RETRIES=8
BYBIT_WORKERS=16
BYBIT_REQUEST_INTERVAL=0.1
BYBIT_MAX_RETRIES=8
BYBIT_CATEGORIES="linear inverse"

# Full parquet audit is useful but expensive; keep opt-in for fast daily updates.
RUN_DATA_QUALITY_AUDIT=0
AUDIT_ROOTS="data_yahoo/tw_stocks data_yahoo/us_stocks data_yahoo/forex data_yahoo/crypto data_okx data_bybit data_forex_frankfurter data_peperstone"
AUDIT_OUTPUT_DIR=artifacts/data_quality
AUDIT_WORKERS=16
AUDIT_STALE_MAX_LAG_DAYS=14
AUDIT_DAILY_GAP_DAYS=10
AUDIT_INTRADAY_GAP_MULTIPLE=4

TW_CLOSE_TZ=Asia/Taipei
TW_CLOSE_TIME=13:40
US_CLOSE_TZ=America/New_York
US_CLOSE_TIME=16:20
FOREX_CLOSE_TZ=America/New_York
FOREX_CLOSE_TIME=17:10
CEX_CLOSE_TZ=UTC
CEX_CLOSE_TIME=00:10
