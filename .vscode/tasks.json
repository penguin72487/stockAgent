{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local Codex: Run Prompt",
      "type": "shell",
      "command": "/home/user/.codex/skills/local-llamacpp-codex/scripts/local-codex",
      "args": [
        "-C",
        "${workspaceFolder}",
        "--max-steps",
        "12",
        "--max-tokens",
        "2400",
        "${input:localCodexPrompt}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Local Codex: Explainability Artifact",
      "type": "shell",
      "command": "/home/user/.codex/skills/local-llamacpp-codex/scripts/local-codex",
      "args": [
        "-C",
        "${workspaceFolder}",
        "--max-steps",
        "8",
        "--max-tokens",
        "3600",
        "--tool-output-chars",
        "90000",
        "--min-tool-calls",
        "1",
        "--require-tool",
        "artifact_bundle",
        "--require-path",
        "explainability_formal_20260617",
        "請呼叫 artifact_bundle 讀取 artifacts/explainability_formal_20260617，max_chars 設 90000，根據證據解釋結果。"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Local Codex: Git Status Diff",
      "type": "shell",
      "command": "/home/user/.codex/skills/local-llamacpp-codex/scripts/local-codex",
      "args": [
        "-C",
        "${workspaceFolder}",
        "--max-steps",
        "4",
        "--max-tokens",
        "1200",
        "--min-tool-calls",
        "1",
        "--require-tool",
        "git_status",
        "請呼叫 git_status(include_diff=true)，整理目前變更。"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "localCodexPrompt",
      "type": "promptString",
      "description": "Task for the full-access local-codex agent",
      "default": "請自己用 project_map、rg_search、read_file 讀專案並簡短整理。"
    }
  ]
}
